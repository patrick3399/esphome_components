[flake8]
# Match ESPHome's C++ column limit for consistency
max-line-length = 120

# W503: line break before binary operator (conflicts with W504, ignore one)
# E203: whitespace before ':' (false positive with slice notation)
extend-ignore = W503, E203

exclude =
    .git,
    __pycache__,
    .venv,
    venv
